# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENAI_API_KEY: Secret key for accessing OpenAI services (server-side only)
OPENAI_API_KEY="your_openai_api_key_here"

# OPENAI_MODEL: Model to target for the responses API (defaults to gpt-5.6)
OPENAI_MODEL="gpt-5.6"

# DEMO_MODE: Explicit flag to enable high-fidelity pre-configured simulation fixtures (true/false)
DEMO_MODE="true"
